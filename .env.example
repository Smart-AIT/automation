# --- Required for Birthday Automation ---

# (Required) Service Role Key to bypass Row Level Security (RLS) during the cron job
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# (Required) WhatsApp API credentials
WHATSAPP_TOKEN=your_whatsapp_access_token
PHONE_NUMBER_ID=your_whatsapp_phone_number_id

# (Optional) Vercel Cron Secret (to secure the endpoint in production)
CRON_SECRET=your_generated_cron_secret
